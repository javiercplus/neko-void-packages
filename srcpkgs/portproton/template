do_install() {
	# Crear estructura de directorios
	vmkdir usr/lib/portproton
	vmkdir usr/bin
	vmkdir usr/share/applications
	vmkdir usr/share/icons/hicolor/scalable/apps
	vmkdir usr/share/metainfo
	vmkdir usr/share/licenses/portproton

	# Copiar contenido
	cp -r ${wrksrc}/* ${DESTDIR}/usr/lib/portproton/

	# Hacer ejecutable el script principal
	chmod +x ${DESTDIR}/usr/lib/portproton/portproton
        chmod +x ${DESTDIR}/usr/lib/portproton/portprotonvoid
	# Crear enlace simbólico
	ln -sf /usr/lib/portproton/portproton ${DESTDIR}/usr/bin/portproton
        ln -sf /usr/lib/portproton/portprotonvoid ${DESTDIR}/usr/bin/portprotonvoid

	# Instalar archivos
	vinstall ${wrksrc}/ru.linux_gaming.PortProton.desktop 644 usr/share/applications
	vinstall ${wrksrc}/ru.linux_gaming.PortProton.svg 644 usr/share/icons/hicolor/scalable/apps
	vinstall ${wrksrc}/ru.linux_gaming.PortProton.metainfo.xml 644 usr/share/metainfo
	vinstall ${wrksrc}/LICENSE 644 usr/share/licenses/portproton
}

post_install() {
	# Actualizar cachés
	gtk-update-icon-cache -qf usr/share/icons/hicolor 2>/dev/null || true
	update-desktop-database -q usr/share/applications 2>/dev/null || true
}