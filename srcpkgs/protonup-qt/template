# Template file for 'protonup-qt'
pkgname=protonup-qt
version=2.15.0
revision=1
build_style=python3-pep517
hostmakedepends="python3-setuptools python3-wheel"
depends="python3-pyside6 python3-pyside6-gui python3-pyside6-widgets python3-pyside6-network python3-pyside6-ui-tools python3-pyside6-dbus python3-requests python3-vdf python3-inputs python3-xdg python3-steam python3-yaml python3-zstandard"
short_desc="Install and manage GE-Proton and Luxtorpeda for Steam and Wine-GE"
maintainer="JavierC"
license="GPL-3.0-or-later"
homepage="https://davidotek.github.io/protonup-qt"
changelog="https://raw.githubusercontent.com/DavidoTek/ProtonUp-Qt/main/CHANGELOG.md"
distfiles="https://github.com/DavidoTek/ProtonUp-Qt/archive/refs/tags/v${version}.tar.gz"
checksum=d06fae6748c811ac942e3cd2a1d3de3efbf330b442323580ebe9b581f39546da

post_patch() {
	# Corregir dependencias y el comando del ejecutable en el .desktop
	vsed -i 's/PySide6-Essentials/PySide6/g' requirements.txt setup.py setup.cfg pyproject.toml 2>/dev/null || true
	vsed -i 's/Exec=net.davidotek.pupgui2/Exec=protonup-qt/g' share/applications/net.davidotek.pupgui2.desktop
}

post_install() {
	# Instalamos el lanzador y la metadata
	vinstall share/applications/net.davidotek.pupgui2.desktop 644 usr/share/applications
	vinstall share/metainfo/net.davidotek.pupgui2.appdata.xml 644 usr/share/metainfo

	# Copiamos toda la carpeta de iconos hicolor a usr/share/icons/
	vcopy share/icons/hicolor usr/share/icons
}
