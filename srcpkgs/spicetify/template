# Template file for 'spicetify'
pkgname=spicetify
version=2.42.11
revision=1
build_style=go
go_import_path="github.com/spicetify/cli"
hostmakedepends="go"
short_desc="Command-line tool to customize Spotify client"
maintainer="JavierC"
license="LGPL-2.1-only"
homepage="https://spicetify.app/"
distfiles="https://github.com/spicetify/cli/archive/refs/tags/v${version}.tar.gz"
checksum=f1b8fc1ed32a128d9d432971085c6d698eaf31f70d8294c349607eba74a3108f

post_install() {
	# Instalamos los activos necesarios en una ruta global compartida
	vmkdir usr/share/spicetify-cli
	for d in Themes Extensions CustomApps jsHelper css-map.json globals.d.ts; do
		vcopy "$d" usr/share/spicetify-cli
	done

	# El sistema de construcción de Go genera el binario como 'cli'
	# Lo renombramos a 'spicetify' para que sea el comando estándar
	mv ${DESTDIR}/usr/bin/cli ${DESTDIR}/usr/bin/spicetify
}
