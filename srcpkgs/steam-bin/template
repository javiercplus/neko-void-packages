pkgname=steam-bin
version=1.0.0.82
revision=1
archs="x86_64"
create_wrksrc=yes
short_desc="Digital distribution platform by Valve (binary version)"
maintainer="Javiercplus"
license="custom:Valve-EULA"
homepage="https://store.steampowered.com/about/"
distfiles="https://codeberg.org/javiercplus/STEAM-ALT-VOID/raw/branch/main/steam_latest.deb"
checksum=b44634a6a604ca7c8b23809d0f2a921a0348bb2081c8cb8944116d0799872b70

hostmakedepends="tar xz"

depends="desktop-file-utils hicolor-icon-theme xdg-utils zenity
 libgcc-32bit libstdc++-32bit libdrm-32bit libglvnd-32bit libibus libibus-32bit
 mesa-vulkan-intel-32bit mesa-vulkan-radeon-32bit vulkan-loader-32bit
 libopenal-32bit libXrandr-32bit libnm-32bit dbus-glib libXtst libdrm
 libpciaccess libxshmfence nss-32bit nss p11-kit p11-kit-32bit gtk+-32bit gdk-pixbuf-32bit libcurl
 gtk+-32bit libpipewire-32bit libva-32bit libvdpau-32bit libvdpau mesa-dri mesa-dri-32bit steam-udev-rules SDL2 SDL2-32bit"

conflicts="steam"
provides="steam-${version}_${revision}"

do_extract() {
    # Al tener create_wrksrc=yes, ya estamos dentro de la carpeta correcta.
    # Usamos 'ar' del sistema (que viene en el bootstrap)
    ar x ${XBPS_SRCDISTDIR}/${pkgname}-${version}/steam_latest.deb
    tar xf data.tar.xz
}

do_install() {
    vmkdir usr/lib
    cp -a usr/lib/steam ${DESTDIR}/usr/lib/
    
    vmkdir usr/bin
    cp -a usr/bin/* ${DESTDIR}/usr/bin/

    vmkdir usr/share
    for dir in applications doc icons man metainfo pixmaps; do
        if [ -d usr/share/$dir ]; then
            cp -a usr/share/$dir ${DESTDIR}/usr/share/
        fi
    done

    vmkdir usr/lib/udev/rules.d
    cp -a lib/udev/rules.d/*.rules ${DESTDIR}/usr/lib/udev/rules.d/

    vlicense usr/share/doc/steam-launcher/copyright
}
