# Template file for 'windscribe-desktop'
pkgname=windscribe-desktop
version=2.19.7
revision=1
archs="x86_64"
build_style=fetch
short_desc="Windscribe Desktop VPN Client (proprietary)"
maintainer="Javiercplus"
license="custom:proprietary"
homepage="https://windscribe.com"
distfiles="https://codeberg.org/javiercplus/Windscribe-void/raw/branch/main/windscribe_${version}_amd64.deb"
checksum=6b1c0027a3d8ff1603064b5dfcef47eb91a2f9af3cbd06549fe1155abf15128e
nostrip_files="
	/opt/windscribe/Windscribe
	/opt/windscribe/helper
	/opt/windscribe/windscribectrld
	/opt/windscribe/windscribe-cli
	/opt/windscribe/windscribe-authhelper
	/opt/windscribe/windscribeopenvpn
	/opt/windscribe/windscribewireguard
	/opt/windscribe/windscribewstunnel
"
do_install() {
	# Extraer el .deb directamente en ${DESTDIR}
	vextract -C "${DESTDIR}" "windscribe_${version}_amd64.deb"

	# 1. Eliminar artefactos de systemd (no usados en Void)
	rm -rf "${DESTDIR}/usr/lib/systemd"

	# 2. Eliminar autostart legacy (no compatible con runit)
	rm -rf "${DESTDIR}/etc/windscribe/autostart"

	# 3. Hacer el CLI accesible globalmente
	vmkdir usr/bin
	ln -sf /opt/windscribe/windscribe-cli "${DESTDIR}/usr/bin/windscribe"

	# 4. Ajustar el lanzador .desktop 
	sed -i 's|^Exec=.*|Exec=/opt/windscribe/Windscribe|' \
		"${DESTDIR}/usr/share/applications/windscribe.desktop"

	# 5. Normalizar nombres de íconos (minúsculas)
	for size in 16 24 32 48 64 128 256; do
		if [ -f "${DESTDIR}/usr/share/icons/hicolor/${size}x${size}/apps/Windscribe.png" ]; then
			mv "${DESTDIR}/usr/share/icons/hicolor/${size}x${size}/apps/Windscribe.png" \
			   "${DESTDIR}/usr/share/icons/hicolor/${size}x${size}/apps/windscribe.png"
		fi
	done
}
